rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Listings collection - main app data
    match /listings/{listingId} {
      // Allow read access to all authenticated users
      allow read: if request.auth != null;
      
      // Allow create for authenticated users (will set createdBy automatically)
      allow create: if request.auth != null 
        && request.auth.uid == request.resource.data.createdBy;
      
      // Allow update/delete only for listing owner
      allow update, delete: if request.auth != null 
        && request.auth.uid == resource.data.createdBy;
    }
    
    // User profiles and other collections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // For development - allow access to other collections
    match /{document=**} {
      allow read: if request.auth != null;
    }
  }
}